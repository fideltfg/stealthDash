# Database Configuration
POSTGRES_USER=dashboard
POSTGRES_PASSWORD=dashboardpass
POSTGRES_DB=dashboard

# Security - Encryption Key for Sensitive Data
# IMPORTANT: Keep this secret! Used to encrypt passwords/API keys in database
ENCRYPTION_KEY=change-me-generate-a-64-char-hex-string

# JWT Secret (CHANGE THIS IN PRODUCTION!)
JWT_SECRET=your-secret-key-change-in-production

# Email Configuration for Password Recovery
# Copy this file to .env and fill in your SMTP details

# SMTP Server Settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false  # true for port 465 (SSL), false for port 587 (TLS)

# SMTP Authentication
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-no-spaces

# Email Sender
EMAIL_FROM=Dashboard <noreply@yourdomain.com>

# Dashboard URL (used in recovery email links)
DASHBOARD_URL=http://localhost:3000

# === Common Email Provider Settings ===

# For Gmail:
# Gmail no longer allows plain account passwords for SMTP.
# You must generate an "App Password" which acts as a simple
# username/password credential for this service (no 2FA prompt involved):
#   1. Enable 2-Step Verification on your Google account (required once)
#   2. Go to https://myaccount.google.com/apppasswords
#   3. Create an App Password for "Mail"
#   4. Set SMTP_USER to your Gmail address
#   5. Set SMTP_PASS to the generated App Password (16-char code, remove spaces)
# The SMTP connection itself uses standard username + password auth.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false

# For Office 365:
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_SECURE=false

# For Outlook.com:
# SMTP_HOST=smtp-mail.outlook.com
# SMTP_PORT=587
# SMTP_SECURE=false

# For Yahoo Mail:
# SMTP_HOST=smtp.mail.yahoo.com
# SMTP_PORT=465
# SMTP_SECURE=true

# For Custom SMTP Server:
# SMTP_HOST=your.smtp.server
# SMTP_PORT=587
# SMTP_SECURE=false

# Vite Server Configuration
# Comma-separated list of allowed hostnames for Vite dev server
VITE_ALLOWED_HOSTS=localhost,.local
